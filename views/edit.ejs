<%- include('partials/header', { titulo: 'Venta Plus - Editar Producto' }) %>

<h2>Editar Producto</h2>
<p class="subtitle"><a href="/productos">&larr; Volver al listado</a></p>

<div class="card">
    <% errores.forEach(function(e) { %>
        <div class="alert alert-error"><%= e %></div>
    <% }); %>

    <form method="POST" action="/productos/<%= producto.idProducto %>?_method=PUT">
        <label for="nombre">Nombre</label>
        <input type="text" id="nombre" name="nombre" maxlength="100" required value="<%= producto.nombre || '' %>">

        <label for="descripcion">Descripcion</label>
        <textarea id="descripcion" name="descripcion" rows="3" maxlength="250"><%= producto.descripcion || '' %></textarea>

        <label for="categoria">Categoria</label>
        <input type="text" id="categoria" name="categoria" maxlength="50" value="<%= producto.categoria || '' %>">

        <label for="precio">Precio</label>
        <input type="number" step="0.01" min="0.01" id="precio" name="precio" required value="<%= producto.precio %>">

        <label for="stock">Stock</label>
        <input type="number" step="1" min="0" id="stock" name="stock" required value="<%= producto.stock %>">

        <label>
            <input type="checkbox" name="activo" style="width:auto; display:inline-block;" <%= producto.activo ? 'checked' : '' %>>
            Activo
        </label>

        <div class="actions" style="margin-top: 20px;">
            <button type="submit" class="btn btn-primary">Actualizar</button>
            <a class="btn btn-secondary" href="/productos">Cancelar</a>
        </div>
    </form>
</div>

<%- include('partials/footer') %>
